{
  "name": "orejime",
  "version": "3.1.2-alpha.0",
  "description": "A lightweight and accessible consent manager",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/boscop-fr/orejime.git"
  },
  "keywords": [
    "cmp",
    "consent management platform",
    "cookie",
    "consent",
    "gdpr",
    "compliance",
    "accessibility",
    "ecofriendly",
    "low footprint",
    "lightweight"
  ],
  "scripts": {
    "start": "rspack --watch",
    "serve": "rspack serve",
    "lint": "prettier --check .",
    "format": "prettier --write .",
    "test-unit": "NODE_OPTIONS=--experimental-vm-modules jest src",
    "test-e2e": "playwright test",
    "test-e2e-ui": "npm run test-e2e -- --ui",
    "test": "npm run test-unit && npm run test-e2e",
    "build": "rspack --mode production",
    "stats": "RSDOCTOR=true rspack build",
    "prepublishOnly": "npm run test && npm run build",
    "prepare": "husky"
  },
  "contributors": [
    "Emmanuel Pelletier",
    "Félix Girault <felix.girault@boscop.fr>"
  ],
  "license": "BSD-3-Clause",
  "bugs": {
    "url": "https://github.com/boscop-fr/orejime/issues"
  },
  "homepage": "https://orejime.boscop.fr",
  "browserslist": [
    "defaults"
  ],
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@rsdoctor/rspack-plugin": "^1.5.12",
    "@rspack/cli": "^2.0.5",
    "@rspack/core": "^2.0.5",
    "@rspack/dev-server": "^2.0.3",
    "@swc/core": "^1.15.40",
    "@swc/helpers": "^0.5.23",
    "@swc/jest": "^0.2.39",
    "@types/jest": "^30.0.0",
    "@types/js-cookie": "^3.0.6",
    "@types/node": "^25.9.1",
    "clean-deep": "^3.4.0",
    "css-loader": "^7.1.4",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "js-cookie": "^3.0.8",
    "postcss-loader": "^8.2.1",
    "postcss-preset-env": "^11.3.0",
    "preact": "^10.29.2",
    "prettier": "^3.8.3",
    "sharp": "^0.34.5",
    "shiki": "^4.1.0",
    "typescript": "^6.0.3",
    "uneval.js": "^5.7.2"
  }
}
